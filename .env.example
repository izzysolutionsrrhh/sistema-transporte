# URL de conexión a PostgreSQL
# Railway: se setea automáticamente al agregar el plugin PostgreSQL
# Supabase: Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# Credenciales del panel de administración
ADMIN_USER=tu_usuario
ADMIN_PASS=tu_contraseña

# Puerto (opcional, por defecto 3000)
PORT=3000

# Zona horaria del servidor (por defecto America/Lima)
APP_TIMEZONE=America/Lima

# Origen permitido para Socket.io (opcional, por defecto * = todos)
# En producción poner el dominio: https://tudominio.com
ALLOWED_ORIGIN=*
